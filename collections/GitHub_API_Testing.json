    {
      "name": "01_Authentication",
      "item": [
        {
          "name": "GET User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verify the API actually knows who you are\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains correct username\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.login).to.not.be.null;\r",
                  "    console.log(\"Authenticated as: \" + jsonData.login);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Purpose: To verify the token works."
    },
