    {
      "name": "Cleanup",
      "item": [
        {
          "name": "New Request",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// List of repos we want to make sure are GONE\r",
                  "if (!pm.collectionVariables.get(\"repos_to_delete\")) {\r",
                  "    pm.collectionVariables.set(\"repos_to_delete\", [\"QA-Automation-2026\", \"QA-Automation-2027\", \"true\"]);\r",
                  "}\r",
                  "\r",
                  "let repos = pm.collectionVariables.get(\"repos_to_delete\");\r",
                  "let currentRepo = repos.shift(); // Get the first one in the list\r",
                  "\r",
                  "pm.environment.set(\"repo_to_clean\", currentRepo);\r",
                  "pm.collectionVariables.set(\"repos_to_delete\", repos);\r",
                  "\r",
                  "console.log(\"Cleaning up repo: \" + currentRepo);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cleanup Successful or Already Deleted\", function () {\r",
                  "    // 204 means deleted, 404 means it was already gone (which is fine for cleanup)\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([204, 404]);\r",
                  "});\r",
                  "\r",
                  "let repos = pm.collectionVariables.get(\"repos_to_delete\");\r",
                  "\r",
                  "if (repos.length > 0) {\r",
                  "    // This is the magic line that repeats the request\r",
                  "    postman.setNextRequest(\"Cleanup - Delete Test Artifacts\");\r",
                  "} else {\r",
                  "    // Stop the loop and clear variables\r",
                  "    pm.collectionVariables.unset(\"repos_to_delete\");\r",
                  "    pm.environment.unset(\"repo_to_clean\");\r",
                  "    console.log(\"Cleanup complete. Environment is fresh.\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "https://api.github.com/repos/thedatafae/{{repo_to_clean}}",
              "protocol": "https",
              "host": [
                "api",
                "github",
                "com"
              ],
              "path": [
                "repos",
                "thedatafae",
                "{{repo_to_clean}}"
              ]
            }
          },
          "response": []
        }
      ]
